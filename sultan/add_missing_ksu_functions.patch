diff --git a/KernelSU/kernel/ksu.c b/KernelSU/kernel/ksu.c
index 0a7b5c3..1e2f8d7 100644
--- a/KernelSU/kernel/ksu.c
+++ b/KernelSU/kernel/ksu.c
@@ -81,6 +81,64 @@ void kernelsu_exit(void)
 	ksu_core_exit();
 }
 
+#include <linux/uaccess.h>
+#include <linux/selinux.h>
+
+#define SU_PATH "/su"
+#define KSUD_PATH "/system/bin/ksud"
+
+int ksu_handle_execveat_ksud(int *fd, struct filename **filename_ptr,
+                             void *argv, void *envp, int *flags)
+{
+    struct filename *filename;
+    const char su[] = SU_PATH;
+
+    if (unlikely(!filename_ptr || !*filename_ptr)) {
+        return 0;
+    }
+
+    filename = *filename_ptr;
+    if (likely(memcmp(filename->name, su, sizeof(su)))) {
+        return 0;
+    }
+
+    pr_info("ksu_handle_execveat_ksud: redirecting %s to %s\n", su, KSUD_PATH);
+    memcpy((void *)filename->name, KSUD_PATH, sizeof(KSUD_PATH));
+    escape_to_root();
+
+    return 0;
+}
+
+int ksu_handle_execve_ksud(const char __user *filename_user,
+                           const char __user *const __user *__argv)
+{
+    int fd = AT_FDCWD;
+    int flags = 0;
+    struct filename *filename = getname(filename_user);
+    int ret;
+
+    if (IS_ERR(filename)) {
+        return PTR_ERR(filename);
+    }
+
+    ret = ksu_handle_execveat_ksud(&fd, &filename, NULL, NULL, &flags);
+    putname(filename);
+    return ret;
+}
+
+int ksu_handle_devpts(struct inode *inode)
+{
+    if (inode == NULL) {
+        return 0;
+    }
+
+    if (susfs_is_current_ksu_domain()) {
+        struct inode_security_struct *isec = inode_security(inode);
+        if (isec) {
+            pr_info("ksu_handle_devpts: labeling inode with KSU devpts SID\n");
+            isec->sid = ksu_get_devpts_sid();
+            isec->initialized = LABEL_INITIALIZED;
+        }
+    }
+
+    return 0;
+}
+
 module_init(kernelsu_init);
 module_exit(kernelsu_exit);
