+#ifdef CONFIG_KSU_SUSFS_SUS_SU
+static int execveat_handler_pre(struct kprobe *p, struct pt_regs *regs)
+{
+    struct filename *filename = (struct filename *)PT_REGS_PARM2(regs);
+    int fd = (int)PT_REGS_PARM1(regs);
+    void *argv = (void *)PT_REGS_PARM3(regs);
+    void *envp = (void *)PT_REGS_PARM4(regs);
+    int flags = (int)PT_REGS_PARM5(regs);
+
+    return ksu_handle_execve_ksud(&fd, &filename, argv, envp, &flags);
+}
+
+static struct kprobe execveat_kp = {
+    .symbol_name = "do_execveat_common",
+    .pre_handler = execveat_handler_pre,
+};
+
+static int devpts_handler_pre(struct kprobe *p, struct pt_regs *regs)
+{
+    struct inode *inode = (struct inode *)PT_REGS_PARM1(regs);
+    struct file *file = (struct file *)PT_REGS_PARM2(regs);
+
+    return ksu_handle_devpts(inode, file);
+}
+
+static struct kprobe devpts_kp = {
+    .symbol_name = "devpts_mknod",
+    .pre_handler = devpts_handler_pre,
+};
